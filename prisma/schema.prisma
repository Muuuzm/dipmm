generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  service   String
  master    String
  date      String
  time      String
  duration  Int      @default(30)
  price     Int?
  publicToken String?  @unique
  comment   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}
